<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jiu-Jitsu Academy SP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <header class="site-header">
        <div class="header-overlay"></div>
        <div class="header-content">
            <p class="header-kicker">Jiu-Jitsu Academy SP</p>
            <h1 class="header-title">@ViewData["Title"]</h1>
            <p class="header-sub">SP com orgulho &middot; in memoriam Leandro Lo</p>
        </div>
    </header>

    <main class="container main-container">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <p class="mb-1"><strong>Jiu-Jitsu Academy SP</strong></p>
            <p class="mb-1">Rua Bueno de Andrade 570 - Aclimacao - Sao Paulo</p>
            <p class="mb-0">Tel: (11) 95127-4423</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
